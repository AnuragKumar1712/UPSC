# PostgreSQL Database Connection
# Format: postgresql://username:password@host:port/database
# For Railway: Get the DATABASE_URL from your Railway PostgreSQL addon
DATABASE_URL=postgresql://user:password@localhost:5432/upsc

# Node Environment
NODE_ENV=development

# Server Port
PORT=3001

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Force password reset on startup (optional)
# FORCE_RESET_PASSWORD=true
